<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Chi Tiêu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName") ?? "";
}
    <header class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">Quản Lý Chi Tiêu</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                @if (userId != null)
                {
                    <li class="nav-item"><a class="nav-link" asp-page="/Transactions/Index">Giao dịch</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Categories/Index">Danh mục</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Users/Index">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Statistics/Index">Thống kê</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Budgets/Index">Ngân sách</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/AI/Index">Trợ lý AI</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Households/Index">Hộ gia đình</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Households/Manage">Quản lý hộ</a></li>
                }
                </ul>
                <ul class="navbar-nav ms-auto">
                @if (userId == null)
                {
                    <li class="nav-item"><a class="nav-link" asp-page="/Account/Login">Đăng nhập</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Account/Register">Đăng ký</a></li>
                }
                else
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @(!string.IsNullOrWhiteSpace(userName) ? userName : "Tài khoản")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted">@Context.Session.GetString("UserEmail")</span></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-page="/Account/Settings">Cài đặt</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form method="post" asp-page="/Account/Logout" class="px-3">
                                    <button type="submit" class="btn btn-link p-0 text-start">Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                </ul>
            </div>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    @* AI chat bubble (renders for signed-in users) *@
    @{ 
        var userIdForChat = Context.Session.GetInt32("UserId");
    }
    @if (userIdForChat != null)
    {
        <partial name="_AiChatPanel" />
    }

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container">
            &copy; @DateTime.Now.Year - Quản Lý Chi Tiêu
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
