@page
@model QuanLyChiTieu.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Danh mục</h1>
    <a class="btn btn-primary" asp-page="Create">Thêm danh mục</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Tên danh mục</th>
            <th style="width: 150px;" class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Categories)
    {
        <tr>
            <td>@item.TenDanhMuc</td>
            <td class="text-center">
                <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@item.MaDanhMuc">Sửa</a>
                <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@item.MaDanhMuc">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
