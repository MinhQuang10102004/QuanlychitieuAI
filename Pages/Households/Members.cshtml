@page
@model QuanLyChiTieu.Pages.Households.MembersModel
@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="container mt-4">
    <h1 class="h3 mb-4">Quản lý thành viên hộ gia đình</h1>

    @if (Model.Household == null)
    {
        <div class="alert alert-warning">Bạn chưa thuộc hộ gia đình nào.</div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">@Model.Household.TenHoGiaDinh</h5>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Tên</th>
                            <th>Email</th>
                            <th>Điện thoại</th>
                            <th>Vai trò</th>
                            <th style="width: 120px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model.Household.ThanhViens ?? new List<QuanLyChiTieu.Models.NguoiDung>())
                        {
                            var isOwner = member.MaNguoiDung == Model.Household.ChuHoId;
                            <tr>
                                <td>@member.HoTen @(isOwner ? "<span class=\"badge bg-primary\">Chủ hộ</span>" : "")</td>
                                <td>@member.Email</td>
                                <td>@(member.Phone ?? "-")</td>
                                <td>
                                    @if (isOwner)
                                    {
                                        <span class="badge bg-primary">Chủ hộ</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Thành viên</span>
                                    }
                                </td>
                                <td>
                                    @if (Model.IsOwner && !isOwner)
                                    {
                                        <form method="post" asp-page-handler="RemoveMember" class="d-inline">
                                            <input type="hidden" name="memberId" value="@member.MaNguoiDung" />
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xoá thành viên này?')">Xoá</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (Model.IsOwner)
                {
                    <div class="mt-3">
                        <a href="/Households/Manage" class="btn btn-primary">Mời thành viên mới</a>
                    </div>
                }
            </div>
        </div>
    }
</div>
