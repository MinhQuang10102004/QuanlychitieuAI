@page
@model QuanLyChiTieu.Pages.Households.ManageModel
@{
    ViewData["Title"] = "Quản lý hộ gia đình";
}

<h1 class="h3 mb-4">Quản lý hộ gia đình</h1>

@if (Model.CurrentHousehold == null)
{
    <div class="alert alert-secondary">Bạn chưa tham gia hộ gia đình nào. <a href="/Households/Create">Tạo hộ gia đình mới</a></div>
}
else
{
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">@Model.CurrentHousehold.TenHoGiaDinh</h5>
        </div>
        <div class="card-body">
            <p><strong>Chủ hộ:</strong> @(Model.CurrentHousehold.ChuHo?.HoTen ?? "Không rõ")</p>

            <h6 class="mb-3">Thành viên (@(Model.CurrentHousehold.ThanhViens?.Count ?? 0))</h6>
            @if (Model.CurrentHousehold.ThanhViens?.Any() == true)
            {
                <table class="table table-sm table-striped">
                    <thead>
                        <tr><th>Tên</th><th>Email</th><th>Điện thoại</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var m in Model.CurrentHousehold.ThanhViens)
                    {
                        <tr>
                            <td>@m.HoTen</td>
                            <td>@m.Email</td>
                            <td>@(m.Phone ?? "-")</td>
                            <td>
                                @if (Model.IsOwner && m.MaNguoiDung != Model.CurrentHousehold.ChuHoId)
                                {
                                    <form method="post" asp-page-handler="Remove" class="d-inline">
                                        <input type="hidden" name="memberId" value="@m.MaNguoiDung" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xoá thành viên?')">Xoá</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">Không có thành viên nào</p>
            }
        </div>
    </div>

    @if (Model.IsOwner)
    {
        <div class="card">
            <div class="card-header bg-light">
                <h6 class="mb-0">Mời thành viên mới</h6>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Invite">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label for="email" class="form-label">Email</label>
                            <input id="email" name="Email" class="form-control" placeholder="Email (hoặc để trống)" />
                        </div>
                        <div class="col-md-4">
                            <label for="phone" class="form-label">Điện thoại</label>
                            <input id="phone" name="Phone" class="form-control" placeholder="Số điện thoại (hoặc để trống)" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">Gửi lời mời</button>
                        </div>
                    </div>
                </form>

                @if (!string.IsNullOrEmpty(Model.InviteToken))
                {
                    <div class="alert alert-success mt-3">
                        <p class="mb-2">✓ Lời mời đã tạo thành công!</p>
                        <div class="input-group">
                            <input type="text" class="form-control" value="@Model.InviteToken" readonly id="tokenInput" />
                            <button class="btn btn-outline-secondary" type="button" onclick="copyToken()">Copy</button>
                        </div>
                        <small class="text-muted d-block mt-2">Chia sẻ token này với người bạn muốn mời</small>
                    </div>
                }
            </div>
        </div>
    }
}

<script>
function copyToken() {
    const input = document.getElementById('tokenInput');
    input.select();
    document.execCommand('copy');
    alert('Token đã copy vào clipboard!');
}
</script>
