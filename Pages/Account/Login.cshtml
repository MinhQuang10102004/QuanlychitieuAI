@page
@model QuanLyChiTieu.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 text-center mb-4">Đăng nhập</h1>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Input.HoTen" class="form-label"></label>
                        <input asp-for="Input.HoTen" class="form-control" autocomplete="name" />
                        <span asp-validation-for="Input.HoTen" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" id="loginPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleLoginPassword" aria-label="Toggle password visibility">👁️</button>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                            <a asp-page="/Account/ForgotPassword" class="small">Quên mật khẩu?</a>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                </form>
                <p class="mt-3 text-center">
                    Chưa có tài khoản? <a asp-page="Register">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var pwd = document.getElementById('loginPassword');
            var toggle = document.getElementById('toggleLoginPassword');
            if (!pwd || !toggle) return;
            toggle.addEventListener('click', function () {
                if (pwd.type === 'password') {
                    pwd.type = 'text';
                    toggle.textContent = '🙈';
                } else {
                    pwd.type = 'password';
                    toggle.textContent = '👁️';
                }
            });
        })();
    </script>
}
