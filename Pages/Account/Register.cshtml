@page
@model QuanLyChiTieu.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h4 text-center mb-4">Tạo tài khoản mới</h1>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Input.HoTen" class="form-label"></label>
                        <input asp-for="Input.HoTen" class="form-control" autocomplete="name" />
                        <span asp-validation-for="Input.HoTen" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Phone" class="form-label">Số điện thoại (tùy chọn)</label>
                        <input asp-for="Input.Phone" class="form-control" autocomplete="tel" placeholder="0123456789" />
                        <span asp-validation-for="Input.Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.AccountType" class="form-label">Loại tài khoản</label>
                        <select asp-for="Input.AccountType" class="form-select">
                            <option value="Individual">Cá nhân</option>
                            <option value="Household">Hộ gia đình</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.InviteToken" class="form-label">Mã mời (nếu có)</label>
                        <input asp-for="Input.InviteToken" class="form-control" />
                        <span asp-validation-for="Input.InviteToken" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" id="registerPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleRegisterPassword" aria-label="Toggle password visibility">👁️</button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" id="registerConfirmPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleRegisterConfirmPassword" aria-label="Toggle password visibility">👁️</button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Đăng ký</button>
                </form>
                <p class="mt-3 text-center">
                    Đã có tài khoản? <a asp-page="Login">Đăng nhập</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var pwd = document.getElementById('registerPassword');
            var toggle = document.getElementById('toggleRegisterPassword');
            if (pwd && toggle) {
                toggle.addEventListener('click', function () {
                    if (pwd.type === 'password') {
                        pwd.type = 'text';
                        toggle.textContent = '🙈';
                    } else {
                        pwd.type = 'password';
                        toggle.textContent = '👁️';
                    }
                });
            }

            var pwd2 = document.getElementById('registerConfirmPassword');
            var toggle2 = document.getElementById('toggleRegisterConfirmPassword');
            if (pwd2 && toggle2) {
                toggle2.addEventListener('click', function () {
                    if (pwd2.type === 'password') {
                        pwd2.type = 'text';
                        toggle2.textContent = '🙈';
                    } else {
                        pwd2.type = 'password';
                        toggle2.textContent = '👁️';
                    }
                });
            }

            // Phone auto-format
            var phoneEl = document.querySelector('[asp-for="Input.Phone"]') || document.getElementById('Input_Phone') || document.querySelector('input[name="Input.Phone"]');
            if (phoneEl) {
                phoneEl.addEventListener('input', function (e) {
                    var v = phoneEl.value || '';
                    var digits = v.replace(/\D/g, '');

                    // If starts with 0 -> keep leading 0, else if starts with country code (84) keep +84
                    if (digits.startsWith('84')) {
                        // format +84 X XXX XXXX -> +84 9 123 4567 (approx)
                        digits = '+' + digits;
                    } else if (digits.startsWith('0')) {
                        // VN local: 0xx xxx xxxx or 0xxx xxx xxx depending on length
                    }

                    // simple grouping: insert space after 3 and 6 digits for readability
                    var out = '';
                    for (var i = 0; i < digits.length; i++) {
                        out += digits[i];
                        if (i === 2 || i === 5) out += ' ';
                    }
                    phoneEl.value = out.trim();
                });
            }
        })();
    </script>
}
