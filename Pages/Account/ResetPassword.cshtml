@page
@model QuanLyChiTieu.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h5 text-center mb-3">Đặt lại mật khẩu</h1>
                <p class="small text-muted">Nhập mã xác thực nếu có, sau đó nhập mật khẩu mới.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Token" class="form-label">Mã xác thực (nếu có)</label>
                        <input asp-for="Input.Token" class="form-control" />
                        <span asp-validation-for="Input.Token" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.NewPassword" class="form-control" id="resetNewPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleResetNewPassword">👁️</button>
                        </div>
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Input.ConfirmPassword" class="form-control" id="resetConfirmPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleResetConfirmPassword">👁️</button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" asp-page-handler="Change" class="btn btn-primary">Đổi mật khẩu</button>
                        <a asp-page="ForgotPassword" class="btn btn-link">Quay lại yêu cầu khôi phục</a>
                    </div>
                </form>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-info mt-3">@Model.Message</div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function wire(id, btnId) {
                var el = document.getElementById(id);
                var btn = document.getElementById(btnId);
                if (!el || !btn) return;
                btn.addEventListener('click', function () {
                    if (el.type === 'password') { el.type = 'text'; btn.textContent = '🙈'; }
                    else { el.type = 'password'; btn.textContent = '👁️'; }
                });
            }
            wire('resetNewPassword', 'toggleResetNewPassword');
            wire('resetConfirmPassword', 'toggleResetConfirmPassword');
        })();
    </script>
}
