@page
@model QuanLyChiTieu.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h5 text-center mb-3">Khôi phục mật khẩu</h1>
                <p class="small text-muted">Nhập email hoặc số điện thoại để nhận hướng dẫn khôi phục. Nếu bạn đã có mã xác thực, hãy chọn "Đổi mật khẩu" để nhập mật khẩu mới.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Contact" class="form-label">Email hoặc Số điện thoại</label>
                        <input asp-for="Input.Contact" class="form-control" placeholder="example@mail.com hoặc 0123456789" />
                        <span asp-validation-for="Input.Contact" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" asp-page-handler="Send" class="btn btn-primary">Gửi mã/Email khôi phục</button>
                        <a asp-page="ResetPassword" class="btn btn-outline-secondary">Đổi mật khẩu (có mã xác thực)</a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
