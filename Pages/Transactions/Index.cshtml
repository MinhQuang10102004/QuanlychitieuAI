@page
@model QuanLyChiTieu.Pages.Transactions.IndexModel
@{
    ViewData["Title"] = "Danh sách giao dịch";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Giao dịch</h1>
    <a class="btn btn-primary" asp-page="Create">Thêm giao dịch</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Ngày</th>
                <th>Người dùng</th>
                <th>Danh mục</th>
                <th class="text-end">Số tiền</th>
                <th>Mô tả</th>
                <th class="text-center" style="width: 160px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Transactions)
        {
            <tr>
                <td>@item.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                <td>@item.NguoiDung?.HoTen</td>
                <td>@item.DanhMuc?.TenDanhMuc</td>
                <td class="text-end">@item.SoTien.ToString("N0") đ</td>
                <td>@item.MoTa</td>
                <td class="text-center">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@item.MaGiaoDich">Sửa</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@item.MaGiaoDich">Xóa</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
